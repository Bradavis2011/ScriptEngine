{
  "expo": {
    "name": "ClipScript",
    "slug": "clipscript",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "clipscript",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0D"
    },
    "ios": {
      "bundleIdentifier": "com.clipscriptai.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "ClipScript needs camera access to film your teleprompter videos.",
        "NSMicrophoneUsageDescription": "ClipScript needs microphone access to record audio with your videos.",
        "NSPhotoLibraryAddUsageDescription": "ClipScript saves your filmed videos to your photo library."
      }
    },
    "android": {
      "package": "com.clipscriptai.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0B0B0D"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "ClipScript needs camera access to film your teleprompter videos.",
          "microphonePermission": "ClipScript needs microphone access to record audio."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "ClipScript needs access to your photo library to save videos.",
          "savePhotosPermission": "ClipScript needs permission to save videos to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "clerkPublishableKey": "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY",
      "apiUrl": "EXPO_PUBLIC_API_URL",
      "router": {},
      "eas": {
        "projectId": "03b4766a-ac26-4243-9608-d103e0860e08"
      }
    },
    "owner": "outfitcheck"
  }
}
