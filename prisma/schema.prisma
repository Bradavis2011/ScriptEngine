generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String   @id @default(cuid())
  clerkUserId   String   @unique
  email         String
  niche         String
  tier          String   @default("free") // free | pro | founders | team
  scriptsPerDay Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  scripts       Script[]
  series        Series[]
}

model Script {
  id              String         @id @default(cuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  scriptType      String         // series_episode | data_drop | trend_take | niche_tip
  scriptData      Json           // coldOpen, sections, callToAction, teleprompterText, caption, hashtags, totalDuration
  filmingStatus   String         @default("ready") // ready | filmed | posted
  public          Boolean        @default(false)   // opt-in: visible in public script library
  seriesId        String?
  series          Series?        @relation(fields: [seriesId], references: [id])
  promptVersionId String?
  promptVersion   PromptVersion? @relation(fields: [promptVersionId], references: [id])
  performance     Json?          // { views, likes, shares, follows, engagementScore }
  aiQualityScore  Float?         // from AI evaluator (1-10)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([tenantId, filmingStatus])
  @@index([tenantId, createdAt])
  @@index([promptVersionId])
}

model Series {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  episodeCount Int      @default(0)
  status       String   @default("in_progress") // in_progress | complete
  scripts      Script[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

model PromptVersion {
  id          String   @id @default(cuid())
  scriptType  String   // data_drop | trend_take | niche_tip | niche_tip_basic | series_episode
  prompt      String   // the full prompt text
  status      String   @default("current") // current | challenger | retired
  source      String   @default("manual")  // manual | ai_lab | ai_calibration
  avgAiScore  Float?   // average AI evaluator score across scripts
  avgEngScore Float?   // average engagement score from real user data
  scriptCount Int      @default(0)
  parentId    String?  // which version this was derived from
  scripts     Script[]
  createdAt   DateTime @default(now())

  @@index([scriptType, status])
}

model ExperimentRun {
  id              String    @id @default(cuid())
  scriptType      String
  currentId       String    // PromptVersion id for current
  challengerId    String    // PromptVersion id for challenger
  evaluationType  String    // ai_judge | user_reported | dual
  status          String    @default("running") // running | completed | insufficient_data
  result          String?   // promoted | rejected | inconclusive
  currentScore    Float?
  challengerScore Float?
  sampleSize      Int       @default(0)
  log             Json?     // detailed run log
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
}

model ConciergeOrder {
  id              String   @id @default(cuid())
  stripePaymentId String   @unique
  email           String
  niche           String?
  topic           String?
  orderType       String   @default("concierge") // pack | concierge
  // concierge extra fields
  brief           String?  // raw brief from customer form
  platform        String?  // tiktok | reels | shorts | all
  stage           String?  // starting | 1k-10k | 10k-100k | 100k+
  audience        String?  // target viewer description
  goals           String?  // grow | sell | authority | brand-deals
  scriptDelivered Boolean  @default(false)
  reportToken     String?  @unique @default(cuid())
  reportHtml      String?
  createdAt       DateTime @default(now())
}
